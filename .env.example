# ── 数据库 ──
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot
DB_USER=trading_user
DB_PASSWORD=your_secure_password

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Discord ──
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_ADMIN_CHANNEL_ID=your_channel_id

# ── Telegram（备用渠道）──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── AI 配置（可插拔，支持多种提供商）──

# AI 提供商选择：anthropic | openai | azure | custom
AI_PROVIDER=anthropic

# AI API 密钥（必需）
AI_API_KEY=your_api_key_here

# 自定义 API 地址（可选，用于 OpenAI 兼容的 API）
# 例如：https://api.openai.com/v1 或 https://your-custom-api.com/v1
AI_API_BASE_URL=

# AI 模型名称（可选）
# Anthropic: claude-sonnet-4-20250514
# OpenAI: gpt-4-turbo-preview
# Azure: 你的部署名称
# Custom: 你的模型名称
AI_MODEL=claude-sonnet-4-20250514

# AI 调用限制
AI_DAILY_CALL_LIMIT=500
AI_HOURLY_COST_ALERT_USD=5.0
AI_HOURLY_COST_BRAKE_USD=10.0

# 兼容旧配置（可选，如果设置了 AI_API_KEY 则忽略）
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── 富途 API ──
FUTU_API_HOST=127.0.0.1
FUTU_API_PORT=11111
FUTU_ORDER_MODE=B
FUTU_TRD_ENV=SIMULATE
FUTU_TRADE_ACC_ID=
FUTU_TRADE_ACC_INDEX=0
FUTU_TRADE_PASSWORD=
FUTU_TRADE_PASSWORD_MD5=
FUTU_AUTO_UNLOCK=true
FUTU_FALLBACK_TO_PLAN_B=true
FUTU_ORDER_PRICE_SLIPPAGE_PCT=0.01

# ── 加密密钥 ──
ENCRYPTION_KEY=your_32_byte_hex_encryption_key
ENCRYPTION_IV=your_16_byte_hex_iv

# ── JWT ──
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── 资讯数据源配置 ──

# 资讯适配器配置（JSON 格式）
# 支持类型：api, skill, mcp, custom
NEWS_ADAPTERS=

# 传统 API 配置
YAHOO_FINANCE_API_KEY=optional_if_using_free_tier
ALPHA_VANTAGE_API_KEY=your_key
EASTMONEY_API_KEY=optional
COINGECKO_API_KEY=optional_free_tier_available

# MCP 服务器配置（示例）
MCP_NEWS_SERVER=http://localhost:3001
MCP_NEWS_TOOL=fetch_news

# Skill 配置（示例）
SKILL_SERVER=http://localhost:3002
SKILL_NAME=news-fetcher

# ── 告警 ──
SENTRY_DSN=your_sentry_dsn
ADMIN_DISCORD_USER_ID=your_discord_user_id

# ── 系统配置 ──
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
COLD_START_MODE=true
