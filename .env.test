# 测试环境变量
NODE_ENV=test
PORT=3001
LOG_LEVEL=error

# 测试数据库
DATABASE_URL=postgresql://test:test@localhost:5432/trading_bot_test
REDIS_URL=redis://localhost:6379/1

# Discord (测试用)
DISCORD_BOT_TOKEN=test_token
DISCORD_CLIENT_ID=test_client_id

# AI (测试用)
ANTHROPIC_API_KEY=test_api_key
AI_DAILY_CALL_LIMIT=100

# 富途
FUTU_API_HOST=127.0.0.1
FUTU_API_PORT=11111
FUTU_ORDER_MODE=B

# 加密密钥 (测试用固定值)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_IV=0123456789abcdef0123456789abcdef

# JWT
JWT_SECRET=test_jwt_secret_for_testing_only_min_32_chars
JWT_EXPIRES_IN=7d

# 系统配置
COLD_START_MODE=true

